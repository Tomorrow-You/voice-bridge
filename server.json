{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dwarmerdam/voice-bridge",
  "title": "Voice Bridge",
  "description": "Multi-engine TTS for AI coding assistants. Free, 5 engines, no API key needed.",
  "repository": {
    "url": "https://github.com/Tomorrow-You/voice-bridge",
    "source": "github",
    "id": "1193132463"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "ai-voice-bridge",
      "version": "0.1.2",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "pypi",
      "identifier": "ai-voice-bridge",
      "version": "0.1.2",
      "runtimeHint": "python",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "-m",
          "description": "Run as module"
        },
        {
          "type": "positional",
          "value": "voice_bridge.mcp.server",
          "description": "MCP server module"
        }
      ]
    }
  ]
}
